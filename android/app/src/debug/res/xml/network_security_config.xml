<?xml version="1.0" encoding="utf-8"?>
<!--
    Configuration réseau pour les builds DEBUG uniquement.
    Autorise HTTP en clair vers n'importe quelle adresse (IP ou hostname).
    Utilisé automatiquement par Android Studio lors des tests (Run/Debug).
    Ce fichier ne s'applique JAMAIS aux builds de production (release).
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
