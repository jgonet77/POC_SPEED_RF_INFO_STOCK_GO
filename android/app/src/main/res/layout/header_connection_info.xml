<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:background="@color/purple_700"
    android:padding="12dp"
    android:gravity="center"
    android:layout_marginBottom="16dp">

    <!-- Column 1: Database -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/header_label_database"
            android:textSize="12sp"
            android:textColor="@color/white_semi_transparent"
            android:layout_marginBottom="4dp" />
        <TextView
            android:id="@+id/headerDatabaseName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/header_database_default"
            android:textSize="14sp"
            android:textColor="@color/white"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Divider 1 -->
    <View
        android:layout_width="1dp"
        android:layout_height="40dp"
        android:background="@color/white_light_transparent"
        android:contentDescription=""
        android:layout_marginHorizontal="12dp" />

    <!-- Column 2: User -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/header_label_user"
            android:textSize="12sp"
            android:textColor="@color/white_semi_transparent"
            android:layout_marginBottom="4dp" />
        <TextView
            android:id="@+id/headerUserLogin"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/header_placeholder"
            android:textSize="14sp"
            android:textColor="@color/white"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Divider 2 -->
    <View
        android:layout_width="1dp"
        android:layout_height="40dp"
        android:background="@color/white_light_transparent"
        android:contentDescription=""
        android:layout_marginHorizontal="12dp" />

    <!-- Column 3: Activity -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/header_label_activity"
            android:textSize="12sp"
            android:textColor="@color/white_semi_transparent"
            android:layout_marginBottom="4dp" />
        <TextView
            android:id="@+id/headerActivityCode"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/header_placeholder"
            android:textSize="14sp"
            android:textColor="@color/white"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>
