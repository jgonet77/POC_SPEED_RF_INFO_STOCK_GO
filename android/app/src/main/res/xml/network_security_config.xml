<?xml version="1.0" encoding="utf-8"?>
<!--
    Configuration réseau pour les builds de PRODUCTION (release).
    HTTPS obligatoire pour tous les domaines externes.
    Cleartext autorisé uniquement pour localhost et l'émulateur Android.

    Pour les tests en réseau local, utiliser un build DEBUG :
    le fichier src/debug/res/xml/network_security_config.xml prend le dessus
    automatiquement et autorise HTTP en clair vers toute adresse.
-->
<network-security-config>
    <!-- Émulateur Android (10.0.2.2 = machine hôte depuis l'émulateur) -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">localhost</domain>
        <domain includeSubdomains="false">10.0.2.2</domain>
    </domain-config>

    <!-- Toutes les autres connexions : HTTPS uniquement -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
