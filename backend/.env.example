# ============================================
# Configuration de l'API Stock
#
# ⚠️ IMPORTANT:
# - Dupliquez ce fichier en ".env"
# - Remplissez vos paramètres
# - Ne commitez PAS le .env en Git (utiliser .gitignore)
# - Les secrets sont à lire depuis ce fichier UNIQUEMENT
# ============================================

# ============================================
# 🗄️  BASE DE DONNÉES SQL SERVER
# ============================================

# Hostname du serveur SQL Server
# Format: SERVEUR ou SERVEUR\INSTANCE ou 192.168.1.100
# Exemples:
#   - LAPVMI116\SQL2019      (Instance nommée)
#   - SQLSERVER.local        (DNS)
#   - 192.168.1.100          (Adresse IP)
SQL_SERVER_HOST=LAPVMI116\SQL2019

# Port SQL Server (défaut: 1433)
# Ne change que si SQL Server est sur un port non-standard
SQL_SERVER_PORT=1433

# Nom de la base de données
# Créer la BD dans SQL Server avant de lancer l'API
SQL_SERVER_DB=POC_V8SpeedDeveloppement

# Utilisateur SQL Server
# ⚠️  Doit avoir les permissions SELECT sur les tables
SQL_SERVER_USER=sa

# Mot de passe SQL Server
# ⚠️  REQUIS - Ne doit pas être vide
# 🔒 Ne jamais le commit en Git
SQL_SERVER_PASSWORD=BKS


# ============================================
# 🌐 CONFIGURATION API
# ============================================

# Host sur lequel écouter l'API
# 0.0.0.0          → Accessible depuis n'importe quelle interface (réseau)
# 127.0.0.1        → Localhost uniquement
# 192.168.1.20     → Interface spécifique
API_HOST=0.0.0.0

# Port d'écoute de l'API
# Défaut: 8000
# Autres choix courants: 5000, 3000, 8080
API_PORT=8000

# Mode auto-reload (développement uniquement)
# true  → Reload automatique si fichiers modifiés
# false → Production (défaut)
API_RELOAD=false

# Origines CORS autorisées (séparées par virgule)
# Format: http://host:port
# Exemple: http://localhost:3000,http://192.168.1.100:8000
CORS_ORIGINS=http://localhost:3000,http://10.0.2.2:3000


# ============================================
# 📋 NOTES DE CONFIGURATION
# ============================================

# Pour obtenir les paramètres SQL Server:
# 1. Ouvrir SQL Server Management Studio
# 2. Vue d'ensemble → Connection → Server name
# 3. Ou utiliser: sqlcmd -L  pour lister les serveurs

# Pour les adresses IP:
# Windows: ipconfig
# Linux:   ip addr show
# Mac:     ifconfig

# Pour tester la connexion:
# python -c "import pyodbc; pyodbc.connect(...)"
# sqlcmd -S SERVEUR -U USER -P PASS -d DB -Q "SELECT @@VERSION"

# Ports à ouvrir dans le firewall:
# - 1433 (SQL Server)
# - 8000 (API)
